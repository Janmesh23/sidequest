# --- Root .gitignore for SideQuest ---

# General
.DS_Store
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.log
backend_logs.txt
test_result.txt

# --- Backend (FastAPI) ---
backend/venv/
backend/.venv/
backend/__pycache__/
backend/*/__pycache__/
backend/*.db
backend/chroma_db/
backend/temp_uploads/*
!backend/temp_uploads/.gitkeep

# Models/Large Files
backend/models/

# --- Frontend (Next.js) ---
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel/
frontend/*.tsbuildinfo
frontend/next-env.d.ts

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
__pycache__/
*.pyc
